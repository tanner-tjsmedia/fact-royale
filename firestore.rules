rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Daily leaderboard scores (public read, auth write) ──
    match /scores/{scoreId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.uid;
    }

    // ── User profiles ──────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // Mastery history snapshots
      match /masteryHistory/{entryId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }

      // Per-play quiz history (archive + daily)
      // Each doc keyed by date string: YYYY-MM-DD
      match /quizHistory/{date} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // ── Admin collection (server-side only) ───────────────
    match /admin/{document=**} {
      allow read: if request.auth != null
                  && request.auth.token.email == 'tanner@tjs16media.com';
      allow write: if false;
    }


    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.createdBy ||
        request.auth.uid in resource.data.memberUids
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
    }
    // ── Anonymous play tracking ────────────────────────────
    match /plays/{playId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /emailCaptures/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ── Challenge records ──────────────────────────────────
    // Anyone with the cid can read.
    // Only authenticated users can create (prevents spam).
    // Anyone can write the result field exactly once (write-once guard).
    // Owner can update toName label, or delete if result not yet recorded.
    match /challenges/{cid} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if (resource.data.result == null
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['result']))
                    || (request.auth != null && request.auth.uid == resource.data.from
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['toName']));
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.from
                    && resource.data.result == null;
    }

  }
}
